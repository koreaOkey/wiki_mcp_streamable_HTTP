      "y": 385,
      "width": 170,
      "height": 72,
      "text": "@mcp.tool()\nname=\"wiki_get_page\"\nasync def wiki_get_page()",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#e67700",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
