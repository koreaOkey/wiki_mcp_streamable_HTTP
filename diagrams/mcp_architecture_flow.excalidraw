      "link": null,
      "locked": false
    },
    {
      "id": "sidebar_detail_step3",
      "type": "text",
      "x": 635,
      "y": 470,
      "width": 170,
      "height": 56,
      "text": "async def _run_tool():\n  try: return await func()\n  except: → error JSON",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
